{
  "plansDirectory": "./docs/plans",
  "language": "russian",
  "showTurnDuration": true,
  "spinnerTipsEnabled": true,
  "env": {
    "ENABLE_TOOL_SEARCH": "auto:5",
    "BASH_DEFAULT_TIMEOUT_MS": "120000"
  },
  "permissions": {
    "allow": [
      "Bash(dotnet *)",
      "Bash(pwsh *)",
      "Bash(buf *)",
      "Bash(git status)",
      "Bash(git status *)",
      "Bash(git diff)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git branch *)",
      "Bash(git fetch *)",
      "Bash(git remote *)",
      "Bash(git add *)",
      "Bash(*git commit *)",
      "Bash(git tag *)",
      "Bash(*git stash *)",
      "Bash(git show *)",
      "Bash(git rev-parse *)",
      "Bash(git describe *)",
      "Bash(git -C *)",
      "Bash(*git checkout *)",
      "Bash(*git push *)",
      "Bash(*git pull *)",
      "Bash(*git merge *)",
      "Bash(git mv *)",
      "Bash(*git cherry-pick *)",
      "Bash(*git clean *)",
      "Bash(git config *)",
      "Bash(npm *)",
      "Bash(pnpm *)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(gh *)",
      "Bash(docker ps *)",
      "Bash(docker logs *)",
      "Bash(docker compose *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(which *)",
      "Bash(echo *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(curl *)",
      "Bash(md5 *)",
      "Bash(python3 *)",
      "Bash(xargs *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(chmod *)",
      "Bash(sed *)",
      "Bash(awk *)",
      "Bash(diff *)",
      "Bash(jq *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(ssh *)",
      "Bash(scp *)",
      "Bash(sops *)",
      "Bash(ITEM_ID=*)",
      "Bash(ISSUE_URL=*)",
      "Bash(CURRENT_BRANCH=*)",
      "WebSearch",
      "WebFetch",
      "mcp__github__get_issue",
      "mcp__github__list_issues",
      "mcp__github__create_issue",
      "mcp__github__update_issue",
      "mcp__github__add_issue_comment",
      "mcp__github__search_issues",
      "mcp__github__search_code",
      "mcp__github__search_repositories",
      "mcp__github__search_users",
      "mcp__github__get_file_contents",
      "mcp__github__list_commits",
      "mcp__github__get_pull_request",
      "mcp__github__list_pull_requests",
      "mcp__github__get_pull_request_files",
      "mcp__github__get_pull_request_comments",
      "mcp__github__get_pull_request_reviews",
      "mcp__github__get_pull_request_status",
      "mcp__github__create_pull_request",
      "mcp__github__create_pull_request_review",
      "mcp__github__create_branch",
      "mcp__github__create_or_update_file",
      "mcp__github__create_repository",
      "mcp__github__fork_repository",
      "mcp__github__merge_pull_request",
      "mcp__github__push_files",
      "mcp__github__update_pull_request_branch",
      "mcp__context7__resolve-library-id",
      "mcp__context7__query-docs",
      "mcp__plugin_context7_context7__resolve-library-id",
      "mcp__plugin_context7_context7__query-docs",
      "mcp__postgres__query"
    ],
    "ask": [
      "Bash(*git reset --hard *)",
      "Bash(*git push --force *)",
      "Bash(*git push * --force)",
      "Bash(*rm -rf *)",
      "Bash(*docker rm *)",
      "Bash(*docker rmi *)"
    ],
    "deny": [
      "Read(**/.env.local)",
      "Read(**/secrets/**)",
      "Read(**/*.pem)",
      "Read(**/*.key)"
    ],
    "additionalDirectories": [
      "../libraries/DKH.Architecture",
      "../DKH.Infrastructure"
    ]
  },
  "enabledPlugins": {
    "context7@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "csharp-lsp@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "microsoft-docs@claude-plugins-official": true,
    "beads@beads-marketplace": true,
    "template-bridge@template-bridge-marketplace": true
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(*git commit*)",
            "command": "[ ! -f \"$CLAUDE_PROJECT_DIR/.claude/hooks/dispatch.sh\" ] || bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/dispatch.sh\" block-commit-wrong-branch.sh",
            "statusMessage": "Branch safety check..."
          },
          {
            "type": "command",
            "if": "Bash(*git *)",
            "command": "[ ! -f \"$CLAUDE_PROJECT_DIR/.claude/hooks/dispatch.sh\" ] || bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/dispatch.sh\" block-primary-worktree-switch.sh",
            "statusMessage": "Primary worktree switch check..."
          },
          {
            "type": "command",
            "if": "Bash(*git *)",
            "command": "[ ! -f \"$CLAUDE_PROJECT_DIR/.claude/hooks/dispatch.sh\" ] || bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/dispatch.sh\" block-destructive-git.sh",
            "statusMessage": "Destructive command check..."
          },
          {
            "type": "command",
            "if": "Bash(*git push*)",
            "command": "[ ! -f \"$CLAUDE_PROJECT_DIR/.claude/hooks/dispatch.sh\" ] || bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/dispatch.sh\" block-push-main.sh",
            "statusMessage": "Push safety check..."
          },
          {
            "type": "command",
            "if": "Bash(*git commit*)",
            "command": "[ ! -f \"$CLAUDE_PROJECT_DIR/.claude/hooks/dispatch.sh\" ] || bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/dispatch.sh\" check-issue-in-branch.sh",
            "statusMessage": "Checking issue in branch..."
          },
          {
            "type": "command",
            "if": "Bash(*git commit*)",
            "command": "[ ! -f \"$CLAUDE_PROJECT_DIR/.claude/hooks/dispatch.sh\" ] || bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/dispatch.sh\" validate-commit-message.sh",
            "statusMessage": "Commit message validation..."
          },
          {
            "type": "command",
            "if": "Bash(*git commit*)",
            "command": "[ ! -f \"$CLAUDE_PROJECT_DIR/.claude/hooks/dispatch.sh\" ] || bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/dispatch.sh\" auto-phase-to-github.sh",
            "statusMessage": "Checking for phase auto-issue..."
          },
          {
            "type": "command",
            "command": "[ ! -f \"$CLAUDE_PROJECT_DIR/.claude/hooks/dispatch.sh\" ] || bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/dispatch.sh\" block-destructive.sh",
            "statusMessage": "Deep destructive check..."
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "[ ! -f \"$CLAUDE_PROJECT_DIR/.claude/hooks/dispatch.sh\" ] || bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/dispatch.sh\" block-edit-on-main.sh",
            "statusMessage": "Branch check for edit..."
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "[ ! -f \"$CLAUDE_PROJECT_DIR/.claude/hooks/dispatch.sh\" ] || bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/dispatch.sh\" block-edit-on-main.sh",
            "statusMessage": "Branch check for write..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "[ ! -f \"$CLAUDE_PROJECT_DIR/.claude/hooks/dispatch.sh\" ] || bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/dispatch.sh\" auto-plan-to-beads.sh",
            "statusMessage": "Auto-registering plan in beads..."
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "[ ! -f \"$CLAUDE_PROJECT_DIR/.claude/hooks/dispatch.sh\" ] || bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/dispatch.sh\" auto-plan-to-beads.sh",
            "statusMessage": "Auto-registering plan in beads..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(*git commit*)",
            "command": "[ ! -f \"$CLAUDE_PROJECT_DIR/.claude/hooks/dispatch.sh\" ] || bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/dispatch.sh\" reminder-hook.sh commit",
            "statusMessage": "Commit reminder..."
          },
          {
            "type": "command",
            "if": "Bash(*git pull*)",
            "command": "[ ! -f \"$CLAUDE_PROJECT_DIR/.claude/hooks/dispatch.sh\" ] || bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/dispatch.sh\" reminder-hook.sh pull-main",
            "statusMessage": "Pull-main reminder..."
          },
          {
            "type": "command",
            "if": "Bash(*git push*)",
            "command": "[ ! -f \"$CLAUDE_PROJECT_DIR/.claude/hooks/dispatch.sh\" ] || bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/dispatch.sh\" reminder-hook.sh mr-push",
            "statusMessage": "MR-push reminder..."
          },
          {
            "type": "command",
            "command": "[ ! -f \"$CLAUDE_PROJECT_DIR/.claude/hooks/dispatch.sh\" ] || bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/dispatch.sh\" suggest-skills.sh",
            "statusMessage": "Checking for relevant skills..."
          },
          {
            "type": "command",
            "if": "Bash(*git push*)",
            "command": "[ ! -f \"$CLAUDE_PROJECT_DIR/.claude/hooks/dispatch.sh\" ] || bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/dispatch.sh\" remind-board-after-push.sh",
            "statusMessage": "Board status reminder..."
          },
          {
            "type": "command",
            "if": "Bash(*git push*)",
            "command": "[ ! -f \"$CLAUDE_PROJECT_DIR/.claude/hooks/dispatch.sh\" ] || bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/dispatch.sh\" monitor-pipeline-after-push.sh",
            "statusMessage": "Pipeline monitoring..."
          },
          {
            "type": "command",
            "if": "Bash(*git commit*)",
            "command": "[ ! -f \"$CLAUDE_PROJECT_DIR/.claude/hooks/dispatch.sh\" ] || bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/dispatch.sh\" check-plan-on-commit.sh",
            "statusMessage": "Plan persistence check..."
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "[ ! -f \"$CLAUDE_PROJECT_DIR/.claude/hooks/dispatch.sh\" ] || bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/dispatch.sh\" session-cleanup-branches.sh",
            "statusMessage": "Cleaning up merged branches..."
          },
          {
            "type": "command",
            "command": "[ ! -f \"$CLAUDE_PROJECT_DIR/.claude/hooks/dispatch.sh\" ] || bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/dispatch.sh\" auto-close-beads-on-merge.sh",
            "statusMessage": "Auto-closing beads whose issue is merged..."
          },
          {
            "type": "command",
            "command": "[ ! -f \"$CLAUDE_PROJECT_DIR/.claude/hooks/dispatch.sh\" ] || bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/dispatch.sh\" session-workflow-reminder.sh"
          },
          {
            "type": "command",
            "command": "[ ! -f \"$CLAUDE_PROJECT_DIR/.claude/hooks/dispatch.sh\" ] || bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/dispatch.sh\" session-check-user-settings-drift.sh",
            "statusMessage": "Checking ~/.claude/settings.json drift..."
          },
          {
            "type": "command",
            "command": "[ ! -f \"$CLAUDE_PROJECT_DIR/.claude/hooks/dispatch.sh\" ] || bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/dispatch.sh\" session-check-subrepo-settings-drift.sh",
            "statusMessage": "Checking subrepo .claude/settings.json drift..."
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "[ ! -f \"$CLAUDE_PROJECT_DIR/.claude/hooks/dispatch.sh\" ] || bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/dispatch.sh\" pre-compact.sh",
            "statusMessage": "Saving state before compaction..."
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "[ ! -f \"$CLAUDE_PROJECT_DIR/.claude/hooks/dispatch.sh\" ] || bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/dispatch.sh\" post-compact.sh",
            "statusMessage": "Restoring plan context..."
          },
          {
            "type": "command",
            "command": "[ ! -f \"$CLAUDE_PROJECT_DIR/.claude/hooks/dispatch.sh\" ] || bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/dispatch.sh\" check-runaway-output.sh",
            "statusMessage": "Checking summary for runaway garbage..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "[ ! -f \"$CLAUDE_PROJECT_DIR/.claude/hooks/dispatch.sh\" ] || bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/dispatch.sh\" block-stop-on-pipeline.sh",
            "statusMessage": "Verifying CI/CD pipelines..."
          },
          {
            "type": "command",
            "command": "[ ! -f \"$CLAUDE_PROJECT_DIR/.claude/hooks/dispatch.sh\" ] || bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/dispatch.sh\" stop-check-state.sh",
            "statusMessage": "Checking for unfinished work..."
          },
          {
            "type": "command",
            "command": "[ ! -f \"$CLAUDE_PROJECT_DIR/.claude/hooks/dispatch.sh\" ] || bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/dispatch.sh\" session-push-beads.sh",
            "statusMessage": "Pushing beads state to remote..."
          },
          {
            "type": "command",
            "command": "[ ! -f \"$CLAUDE_PROJECT_DIR/.claude/hooks/dispatch.sh\" ] || bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/dispatch.sh\" check-runaway-output.sh",
            "statusMessage": "Checking for runaway output..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "[ ! -f \"$CLAUDE_PROJECT_DIR/.claude/hooks/dispatch.sh\" ] || bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/dispatch.sh\" check-runaway-output.sh",
            "statusMessage": "Checking for runaway output..."
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "[ ! -f \"$CLAUDE_PROJECT_DIR/.claude/hooks/dispatch.sh\" ] || bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/dispatch.sh\" notify-macos.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/dispatch.sh\" statusline.sh"
  },
  "extraKnownMarketplaces": {
    "beads-marketplace": {
      "source": {
        "source": "github",
        "repo": "steveyegge/beads"
      }
    },
    "template-bridge-marketplace": {
      "source": {
        "source": "github",
        "repo": "maslennikov-ig/template-bridge"
      }
    }
  }
}
