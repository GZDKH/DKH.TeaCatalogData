# DKH.TeaCatalogData — production import settings
#
# Copy this file to .env (same folder), fill in the secrets, and save.
# .env is already in .gitignore — it will NOT be committed.

# AdminGateway URL (reachable via Tailscale VPN)
GATEWAY_URL=http://10.10.10.101:5005

# Keycloak (public endpoint behind Cloudflare)
KEYCLOAK_URL=https://auth.thetea.app
KEYCLOAK_REALM=dkh
KEYCLOAK_CLIENT_ID=dkh-admin-gateway

# Fill in from Keycloak Admin UI →
#   realm "dkh" → Clients → "dkh-admin-gateway" → Credentials → "Client secret"
KEYCLOAK_CLIENT_SECRET=<paste-client-secret-here>
KEYCLOAK_GRANT_TYPE=client_credentials
# Optional: short-lived admin Bearer/JWT token. When set, scripts do not call Keycloak.
ADMIN_GATEWAY_ACCESS_TOKEN=

# Required by ProductCatalog export, validate, and import endpoints.
PRODUCT_CATALOG_WORKSPACE_ID=<paste-workspace-uuid-here>

# Service account or password user must satisfy AdminGateway CatalogImport policy:
# super-admin, full-access, catalog-manager, or granular catalog:import.
# Optional password grant fallback. The service account is preferred for automation.
KEYCLOAK_USERNAME=<your-admin-username>
KEYCLOAK_PASSWORD=<your-admin-password>

# Optional: paid TheTea Content API key for localized text cards.
# Supported aliases: THETEA_API_KEY or THE_TEA_API_KEY.
THETEA_API_KEY=<paste-thetea-api-key-here>
